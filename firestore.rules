rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function userData(userId) {
      return userDoc(userId).data;
    }

    function isProfessor() {
      return isAuthenticated() && userData(request.auth.uid).role == "professor";
    }

    function isAluno() {
      return isAuthenticated() && userData(request.auth.uid).role == "aluno";
    }

    function isMinhaTurma(turmaId) {
      return isProfessor() &&
        exists(/databases/$(database)/documents/turmas/$(turmaId)) &&
        get(/databases/$(database)/documents/turmas/$(turmaId)).data.criadoPor == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isProfessor();
      allow create: if isAuthenticated() && (
        request.auth.uid == userId ||
        (isProfessor() && request.resource.data.role == "aluno")
      );
      allow update: if (
        request.auth.uid == userId && request.resource.data.role == resource.data.role
      ) || (
        isProfessor() &&
        resource.data.role == "aluno" &&
        request.resource.data.role == "aluno"
      );
      allow delete: if false;
    }

    match /turmas/{turmaId} {
      allow create: if isProfessor() && request.resource.data.criadoPor == request.auth.uid;
      allow read: if (
        isProfessor() && resource.data.criadoPor == request.auth.uid
      ) || (
        isAluno() && userData(request.auth.uid).turmaId == turmaId
      );
      allow update, delete: if isProfessor() && resource.data.criadoPor == request.auth.uid;
    }

    match /simulados/{simuladoId} {
      allow create: if isProfessor() && request.resource.data.criadoPor == request.auth.uid;
      allow read: if (
        isProfessor() && resource.data.criadoPor == request.auth.uid
      ) || (
        isAluno() &&
        exists(/databases/$(database)/documents/turmas/$(userData(request.auth.uid).turmaId)) &&
        get(/databases/$(database)/documents/turmas/$(userData(request.auth.uid).turmaId)).data.provas.hasAny([simuladoId])
      );
      allow update, delete: if isProfessor() && resource.data.criadoPor == request.auth.uid;
    }

    match /questoes/{questaoId} {
      allow read: if isProfessor() || isAluno();
      allow create: if isProfessor() && (
        request.resource.data.autor == request.auth.uid ||
        request.resource.data.autorId == request.auth.uid
      );
      allow update, delete: if isProfessor() && (
        resource.data.autor == request.auth.uid ||
        resource.data.autorId == request.auth.uid
      );
    }

    match /blocosQuestoes/{blocoId} {
      allow read: if isProfessor();
      allow create: if isProfessor() && (
        request.resource.data.autor == request.auth.uid ||
        request.resource.data.autorId == request.auth.uid
      );
      allow update, delete: if isProfessor() && (
        resource.data.autor == request.auth.uid ||
        resource.data.autorId == request.auth.uid
      );
    }

    match /analisesDescritores/{analiseId} {
      allow read: if isProfessor();
      allow create: if isProfessor() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if false;
    }

    match /configuracoes/{professorId} {
      allow read, create, update: if isProfessor() && professorId == request.auth.uid;
      allow delete: if false;
    }

    match /provas/{provaId} {
      allow create: if isProfessor() && request.resource.data.criadoPor == request.auth.uid;
      allow read: if (
        isProfessor() && resource.data.criadoPor == request.auth.uid
      ) || (
        isAluno() &&
        exists(/databases/$(database)/documents/turmas/$(userData(request.auth.uid).turmaId)) &&
        get(/databases/$(database)/documents/turmas/$(userData(request.auth.uid).turmaId)).data.provas.hasAny([provaId])
      );
      allow update, delete: if isProfessor() && resource.data.criadoPor == request.auth.uid;
    }

    match /respostas/{respostaId} {
      allow create: if isAluno() &&
        request.resource.data.alunoId == request.auth.uid &&
        request.resource.data.turmaId == userData(request.auth.uid).turmaId;

      allow read: if (
        isAluno() && resource.data.alunoId == request.auth.uid
      ) || (
        isProfessor() &&
        resource.data.turmaId is string &&
        isMinhaTurma(resource.data.turmaId)
      );

      allow update: if isProfessor() &&
        resource.data.turmaId is string &&
        isMinhaTurma(resource.data.turmaId);

      allow delete: if false;
    }
  }
}
